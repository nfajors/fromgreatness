# ─────────────────────────────────────────────────────────────
#  fromGreatness — environment configuration
#  Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
APP_ID=fromgreatness                 # any stable identifier
APP_SECRET=                          # REQUIRED in production: long random string used to sign session JWTs
DATABASE_URL=                        # MySQL connection string, e.g. mysql://user:pass@host:3306/fromgreatness
APP_URL=http://localhost:3000        # public origin; used for Stripe redirect URLs
                                     # → in production set this to: https://fromgreatness.app

# ── Stripe (payments) ─────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=                   # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=               # whsec_... (from `stripe listen` or the Dashboard webhook)
STRIPE_PRICE_ANNUAL=                 # price_... for the $75/year recurring price
STRIPE_PRICE_MONTHLY=                # price_... for the $9.99/month recurring price (optional)

# ── Anthropic (AI study-plan generation) ──────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=                   # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Admin ─────────────────────────────────────────────────────
# The first account whose email matches this value becomes an admin.
OWNER_UNION_ID=                      # e.g. email:you@example.com  (or just you@example.com)

# ── Legacy Kimi OAuth (optional — leave blank to disable) ──────
KIMI_AUTH_URL=
KIMI_OPEN_URL=
